{
  "name": "agenv",
  "version": "0.1.0",
  "description": "Manage multiple .agents/ directories per project",
  "module": "src/index.ts",
  "bin": {
    "agenv": "./src/index.ts"
  },
  "scripts": {
    "build": "bun build src/index.ts --compile --outfile dist/agenv --target bun",
    "dev": "bun run src/index.ts",
    "test": "bun test",
    "lint": "bunx tsc --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "1.2.0",
    "@types/node": "25.5.2",
    "commander": "14.0.3",
    "picocolors": "1.1.1",
    "smol-toml": "1.6.1"
  },
  "devDependencies": {
    "@types/bun": "1.3.11",
    "typescript": "6.0.2"
  },
  "type": "module",
  "private": true
}
